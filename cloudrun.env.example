# =====================================================================
# OPCIONAIS
# =====================================================================
GCS_UPLOAD_PREFIX=uploads
MAX_UPLOAD_SIZE_MB=25
MAX_QUEUE_SIZE=20
MAX_STORED_JOBS=300
JOB_RETENTION_SECONDS=3600
